BUFFER_API_KEY=
BUFFER_CHANNEL_ID=

# Required for image posts. Use a public URL prefix where generated images are reachable.
# Example for a public GitHub repo:
# https://raw.githubusercontent.com/YOUR_USER/YOUR_REPO/main/public/generated
BUFFER_PUBLIC_IMAGE_BASE_URL=

# Optional. Geopolitics images use a free no-key image endpoint by default.
# Set false if you only want local fallback graphics.
ENABLE_FREE_AI_IMAGES=true

# Optional: keep true while testing. CLI --dry-run also works.
DRY_RUN=true
